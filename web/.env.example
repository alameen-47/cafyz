# ─── Cafyz web (Vite) env ─────────────────────────────────────────────────────
# Vite only exposes vars prefixed with VITE_ to the browser, and bakes them in
# at BUILD time. On Render/Vercel set these in the static-site build env.

# Backend API origin. Leave empty to use the dev proxy / same-origin in prod.
VITE_API_URL=

# Public app URL (used in copy/links)
VITE_APP_URL=https://cafyz.ametronyx.com

# Free trial length shown in the UI
VITE_TRIAL_DAYS=7

# ─── Cloudinary (restaurant logo uploads) ─────────────────────────────────────
# Lets managers upload a logo from the Restaurant Profile tab. Uses an UNSIGNED
# upload preset so no API secret ever reaches the browser.
#   1. Create a free account at https://cloudinary.com
#   2. Dashboard -> note your "Cloud name".
#   3. Settings -> Upload -> Upload presets -> Add preset, set Signing Mode to
#      "Unsigned". Copy the preset name.
#   4. (optional) set a folder to keep uploads tidy, e.g. restaurant-logos.
# Cloudinary serves images with CORS enabled, so uploaded logos also print
# correctly on Bluetooth/USB thermal printers (canvas raster path).
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_FOLDER=restaurant-logos

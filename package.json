{
  "name": "cafyz",
  "version": "1.0.0",
  "private": true,
  "description": "Cafyz restaurant POS — web, mobile, and desktop",
  "author": "Cafyz",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"cyan,magenta\" \"npm run api\" \"npm run web\"",
    "api": "npm --prefix backend run dev",
    "web": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:build:native": "vite build --config web/vite.config.ts --mode capacitor",
    "gen-icons": "node scripts/gen-icons.mjs",
    "cap:sync": "npm run web:build:native && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "native:build": "bash scripts/build-native.sh all",
    "native:android": "bash scripts/build-native.sh android",
    "native:ios": "bash scripts/build-native.sh ios",
    "native:desktop": "bash scripts/build-native.sh desktop",
    "desktop": "electron .",
    "desktop:pack": "npm run gen-icons && electron-builder",
    "desktop:pack:mac": "npm run gen-icons && electron-builder --mac",
    "desktop:pack:win": "npm run gen-icons && electron-builder --win",
    "desktop:pack:linux": "npm run gen-icons && electron-builder --linux",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.2.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@react-native/new-app-screen": "0.85.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-webview": "^13.16.1",
    "wait-on": "^9.0.10"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.6.2",
    "react-test-renderer": "19.2.3",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.3.0"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "build": {
    "appId": "com.cafyz.desktop",
    "productName": "Cafyz",
    "icon": "build/icon.png",
    "directories": {
      "output": "releases/desktop"
    },
    "files": [
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

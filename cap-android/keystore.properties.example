# Copy to cap-android/keystore.properties (gitignored) and fill in before release builds.
# Generate keystore: keytool -genkey -v -keystore cafyz-release.keystore -alias cafyz -keyalg RSA -keysize 2048 -validity 10000

CAFYZ_RELEASE_STORE_FILE=../cafyz-release.keystore
CAFYZ_RELEASE_STORE_PASSWORD=your-store-password
CAFYZ_RELEASE_KEY_ALIAS=cafyz
CAFYZ_RELEASE_KEY_PASSWORD=your-key-password

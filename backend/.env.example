# Turso (libSQL) — get from https://turso.tech/app
TURSO_URL=libsql://your-db.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT — use a long random string in production (Render can auto-generate)
JWT_SECRET=change-me-in-production

# Founder credentials (only founder account should access /founder)
FOUNDER_EMAIL=founder@cafyz.io
FOUNDER_PASSWORD=change-me-founder-password

# Public web app URL (used in inquiry emails — founder panel link, login link)
APP_URL=https://cafyz.ametronyx.com

# Free trial length for new signups (days)
TRIAL_DAYS=7

# Anti-abuse: block repeated trial requests from same device/IP (days)
TRIAL_REQUEST_COOLDOWN_DAYS=30

# Comma-separated allowed CORS origins
# Production: include your custom domain
ALLOWED_ORIGIN=https://cafyz.ametronyx.com,http://localhost:5173,http://localhost:5174

# Server port (Render injects PORT automatically — do not set manually on Render)
PORT=4000

# Email — inquiry notifications, trial approval, license delivery
#
# Provider priority at runtime:  Resend  ->  Brevo  ->  Gmail SMTP
# Render FREE tier BLOCKS outbound SMTP (465/587), so on Render you MUST use an
# HTTPS API provider (Resend or Brevo). SMTP only works locally or on paid Render.
#
# ── Brevo (recommended for Render free tier — HTTPS API) ──────────────────────
#   1. Sign up at https://www.brevo.com  (300 emails/day free)
#   2. Senders & IP -> add cafyzofficial@gmail.com (or your domain) and VERIFY it.
#   3. SMTP & API -> API Keys -> create a v3 key -> BREVO_API_KEY
#   4. Security -> Authorized IPs -> DISABLE restriction (required for Render;
#      Render outbound IPs change; otherwise you get 401 "unrecognised IP address").
#   5. On Render dashboard, set the same BREVO_* vars (not only in local .env).
#
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=your-verified-sender@gmail.com
BREVO_SENDER_NAME=Cafyz
#
# ── Resend (alternative HTTPS API) ────────────────────────────────────────────
# Requires verifying your domain before you can email arbitrary recipients.
RESEND_API_KEY=
RESEND_FROM="Cafyz" <founder@yourdomain.com>
#
# ── Gmail SMTP (local dev / paid Render only — blocked on Render free) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your@gmail.com
SMTP_FROM_NAME=Cafyz

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
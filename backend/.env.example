# Turso (libSQL) — get from https://turso.tech/app
TURSO_URL=libsql://your-db.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT — use a long random string in production (Render can auto-generate)
JWT_SECRET=change-me-in-production

# Comma-separated allowed CORS origins
# Production: set to your Vercel URL
# ALLOWED_ORIGIN=https://cafyz.vercel.app
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5174

# Server port (Render injects PORT automatically — do not set manually on Render)
PORT=4000

# Email (SMTP) — for inquiry notifications + auto-replies
# Use a Gmail App Password (not your main password): myaccount.google.com > Security > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ametronyxx@gmail.com
SMTP_PASS=your-gmail-app-password

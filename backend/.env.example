# Turso (libSQL) — get from https://turso.tech/app
TURSO_URL=libsql://your-db.aws-ap-south-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# JWT — use a long random string in production (Render can auto-generate)
JWT_SECRET=change-me-in-production

# Founder credentials (only founder account should access /founder)
FOUNDER_EMAIL=founder@cafyz.io
FOUNDER_PASSWORD=change-me-founder-password

# Public web app URL (used in inquiry emails — founder panel link, login link)
APP_URL=https://cafyz.ametronyx.com

# Free trial length for new signups (days)
TRIAL_DAYS=7

# Anti-abuse: block repeated trial requests from same device/IP (days)
TRIAL_REQUEST_COOLDOWN_DAYS=30

# Comma-separated allowed CORS origins
ALLOWED_ORIGIN=https://cafyz.ametronyx.com,http://localhost:5173,http://localhost:5174

PORT=4000

# ── Email (production on Render FREE tier: use Resend — SMTP ports are blocked) ──
#
# Resend setup:
#   1. https://resend.com → API Keys → create key → RESEND_API_KEY=re_...
#   2. For quick testing (no domain): RESEND_FROM=Cafyz <onboarding@resend.dev>
#      (can only send to the email you signed up with until you verify a domain)
#   3. For production: Domains → verify ametronyx.com → RESEND_FROM=Cafyz <noreply@ametronyx.com>
#   4. Copy the same vars to Render → Environment → redeploy
#
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_your_key_here
RESEND_FROM=Cafyz <onboarding@resend.dev>

# Optional: Brevo (if not using Resend)
# EMAIL_PROVIDER=brevo
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=your-verified@gmail.com
# BREVO_SENDER_NAME=Cafyz

# Gmail SMTP — local dev fallback only (blocked on Render free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your@gmail.com
SMTP_FROM_NAME=Cafyz

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

{
  "buildCommand": "npm run web:build",
  "outputDirectory": "web/dist",
  "framework": null,
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cafyz-api.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

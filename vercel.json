{
  "installCommand": "cd web-v2 && npm install",
  "buildCommand": "cd web-v2 && npm run build",
  "outputDirectory": "web-v2/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cafyz.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api/)(?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
